// ============================================================
// SECRETS TEMPLATE — Aman untuk di-commit ke Git.
// Salin file ini menjadi secrets.h dan isi dengan nilai asli.
//
//   cp secrets.h.example secrets.h
//
// JANGAN COMMIT secrets.h! Sudah di-ignore oleh .gitignore.
// ============================================================

#pragma once

// WiFi credentials — isi dengan SSID & password jaringan Anda
#define SECRETS_WIFI_SSID     "nama-wifi-anda"
#define SECRETS_WIFI_PASSWORD "password-wifi-anda"

// API endpoint — ganti dengan IP server Laravel Anda
// Contoh lokal   : "http://192.168.1.100:8000/api/v1/devices"
// Contoh Railway : "https://your-app.up.railway.app/api/v1/devices"
#define SECRETS_API_BASE_URL  "http://IP_SERVER:PORT/api/v1/devices"

// Device token — salin dari dashboard Admin → Devices → Token
#define SECRETS_DEVICE_TOKEN  "ganti-dengan-token-dari-dashboard"
